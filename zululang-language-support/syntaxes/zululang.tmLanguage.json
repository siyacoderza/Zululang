{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Zululang",
  "scopeName": "source.zul",
  "fileTypes": ["zul", "zulu"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.zul",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.zul",
          "match": "\\b(uma|kungenjalo|ngenkathi|umsebenzi|buyisa|kuba|noma|kufika)\\b"
        },
        {
          "name": "keyword.other.zul",
          "match": "\\b(bonisa|cela|njalo)\\b"
        },
        {
          "name": "constant.language.zul",
          "match": "\\b(qiniso|amanga)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.zul",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.zul",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.zul",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.zul",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.zul",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.zul",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.zul",
          "match": "(\\+|-|\\*|/|%|==|!=|<=|>=|<|>|=)"
        }
      ]
    }
  }
}
